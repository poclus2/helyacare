# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NE PAS committer les vraies clés
.env
.env.local
.env.development
# .env.production est un TEMPLATE (sans vraies clés) — OK à committer
# Pour les vraies valeurs en production, utiliser Railway / GitHub Secrets

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Images uploadées par l'admin (grande taille, persistées sur Railway Volume)
public/uploads/*
!public/uploads/.gitkeep

# Logs Railway/Docker
*.log
